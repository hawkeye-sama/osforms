# ─────────────────────────────────────────────────────────────────────────────
# OSForms — environment variables
#
# Copy this file to `.env` in the SAME directory (apps/web), then fill it in:
#   cp apps/web/.env.example apps/web/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# MongoDB connection string.
#   Local Docker (docker compose up -d):  mongodb://localhost:27017/osforms
#   MongoDB Atlas:                         mongodb+srv://<user>:<pass>@<cluster>/osforms
MONGODB_URI=mongodb://localhost:27017/osforms

# Secret used to sign auth JWTs. Any long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string

# AES-256 key for encrypting user API keys at rest. EXACTLY 64 hex chars (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public URL of this app. Used for CORS, redirects, and the Google OAuth callback.
#   Local:      http://localhost:3000
#   Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: Google Sheets integration (Google OAuth) ───────────────────────
# Create OAuth credentials at https://console.cloud.google.com
# (APIs & Services → Credentials → OAuth client ID → Web application).
# Authorized redirect URI MUST be exactly:
#   <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: email (Resend) ─────────────────────────────────────────────────
# API key from https://resend.com/api-keys.
# Powers OTP / verification emails and the Resend email integration.
RESEND_API_KEY=

# Signing secret for the INBOUND Resend email webhook (auto-responder replies).
# Only needed if you wire up Resend inbound email. From the Resend webhook settings.
RESEND_EMAIL_SIGNING_SECRET=
