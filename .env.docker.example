# OSForms Docker config. Copy this file to .env, then edit:
#
#   cp .env.docker.example .env
#
# docker-compose.yml loads this via env_file, so these values become the web
# container's environment. .env is gitignored, so your secrets stay local.

# ── Required ────────────────────────────────────────────────────────────────

# Public URL the browser uses. Baked into the client bundle at build time, so
# after changing it, rebuild: `docker compose up --build`.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate each of these with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY must be exactly 64 hex characters. Do NOT change it once you
# have live data — stored integration keys become undecryptable.
JWT_SECRET=
ENCRYPTION_KEY=

# ── Optional ────────────────────────────────────────────────────────────────

# Database. Defaults to the bundled mongo service, so leave this unset unless
# you want to point at an external MongoDB (e.g. Atlas).
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/osforms

# BYOK integrations. Leave blank to disable. Without RESEND_API_KEY, signup
# OTP emails won't send — read the code from `docker compose logs web`.
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_EMAIL_SIGNING_SECRET=
